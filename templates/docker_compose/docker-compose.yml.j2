services:
  # --- Main Application Service ---
  {{ service.name | lower }}:
    image: "{{ service.image_repo }}:{{ service.image_tag }}"
    container_name: "{{ service.name | lower }}"
    hostname: "{{ service.hostname }}"
    restart: "{{ deployments.docker_compose.restart_policy | default('always') }}"

    {% if deployments.docker_compose.command is defined %}
    command:
      {% for cmd_item in deployments.docker_compose.command %}
      {% if '\n' in cmd_item %}
      - |
{{ cmd_item | indent(8) }}
      {% else %}
      - {{ (cmd_item | string) | tojson }}
      {% endif %}
      {% endfor %}
    {% endif %}

    {% if (config.schema_version | default(1) | int) >= 2 %}
    {% if deployments.docker_compose.environment is defined and deployments.docker_compose.environment is mapping and deployments.docker_compose.environment %}
    environment:
      {% for key, value in deployments.docker_compose.environment.items() %}
      {{ key }}: {{ value | tojson }}
      {% endfor %}
    {% endif %}
    {% else %}
    env_file:
      - .env
      - stack.env
    {% endif %}

    {% if processed_ports %}
    ports:
      {% for p in processed_ports %}
      - "{{ p }}"
      {% endfor %}
    {% endif %}

    {% if processed_volumes %}
    volumes:
      {% for vol in processed_volumes %}
      - "{{ vol }}"
      {% endfor %}
    {% endif %}

    {% if processed_networks %}
    networks:
      {% for net in processed_networks %}
      - {{ net }}
      {% endfor %}
    {% endif %}

    {% if processed_labels %}
    labels:
      {% for key, value in processed_labels.items() %}
      {{ key }}: "{{ value }}"
      {% endfor %}
    {% endif %}

    {% if deployments.docker_compose.healthcheck is defined %}
    healthcheck:
      test: {{ deployments.docker_compose.healthcheck.test | tojson }}
      interval: {{ deployments.docker_compose.healthcheck.interval | default('30s') }}
      timeout: {{ deployments.docker_compose.healthcheck.timeout | default('5s') }}
      retries: {{ deployments.docker_compose.healthcheck.retries | default(3) }}
    {% endif %}

    {# --- SMART SPECS (Python handles all other valid DC keys) --- #}
    {% if processed_specs %}
{{ processed_specs | to_yaml(indent=2) | indent(4, first=true) }}
    {% endif %}

{% if dependencies is defined and dependencies %}
  # --- Service Dependencies (Sidecars) ---
{% for dep_name, dep_config in dependencies.items() %}
  {{ dep_config.name }}:
    image: "{{ dep_config.image_repo }}:{{ dep_config.image_tag }}"
    container_name: "{{ dep_config.name }}"
    restart: "{{ dep_config.restart_policy | default('always') }}"
    
    {% if dep_config.command is defined %}
    command:
      {% for cmd_item in dep_config.command %}
      {% if '\n' in cmd_item %}
      - |
{{ cmd_item | indent(8) }}
      {% else %}
      - {{ (cmd_item | string) | tojson }}
      {% endif %}
      {% endfor %}
    {% endif %}

    {% set dep_inherit_global_env = dep_config.inherit_global_env | default(deployments.docker_compose.dependencies_inherit_global_env | default(true)) %}
    {% if dep_inherit_global_env %}
    env_file:
      - .env
      - stack.env
    {% endif %}

    {% set _v2 = (config.schema_version | default(1) | int) >= 2 %}
    {% if (dep_config.environment is defined and dep_config.environment is mapping and dep_config.environment) or (dep_config.secrets is defined and dep_config.secrets is mapping and dep_config.secrets) %}
    environment:
      {% if dep_config.environment is defined and dep_config.environment is mapping %}
      {% for key, value in dep_config.environment.items() %}
      {{ key }}: {{ (value | tojson) if _v2 else ('"' ~ value ~ '"') }}
      {% endfor %}
      {% endif %}
      {% if dep_config.secrets is defined and dep_config.secrets is mapping %}
      {% for key, value in dep_config.secrets.items() %}
      {{ key }}: {{ (value | tojson) if _v2 else ('"' ~ value ~ '"') }}
      {% endfor %}
      {% endif %}
    {% endif %}

    {% if dep_config.processed_ports %}
    ports:
      {% for p in dep_config.processed_ports %}
      - "{{ p }}"
      {% endfor %}
    {% endif %}

    {% if dep_config.processed_volumes %}
    volumes:
      {% for vol in dep_config.processed_volumes %}
      - "{{ vol }}"
      {% endfor %}
    {% endif %}

    {% if dep_config.processed_networks %}
    networks:
      {% for net in dep_config.processed_networks %}
      - {{ net }}
      {% endfor %}
    {% endif %}

    {% if dep_config.labels is defined %}
    labels:
      {% for key, value in dep_config.labels.items() %}
      {{ key }}: "{{ value }}"
      {% endfor %}
    {% endif %}

    {% if dep_config.healthcheck is defined %}
    healthcheck:
      test: {{ dep_config.healthcheck.test | tojson }}
      interval: {{ dep_config.healthcheck.interval | default('30s') }}
      timeout: {{ dep_config.healthcheck.timeout | default('5s') }}
      retries: {{ dep_config.healthcheck.retries | default(5) }}
    {% endif %}

    {# --- SMART SPECS FOR SIDECARS --- #}
    {% if dep_config.processed_specs %}
{{ dep_config.processed_specs | to_yaml(indent=2) | indent(4, first=true) }}
    {% endif %}

{% endfor %}
{% endif %}

{% if network_definitions %}
networks:
{% for net_id, net_def in network_definitions.items() %}
  {{ net_id }}:
    name: "{{ net_def.name }}"
    {% if net_def.external %}
    external: true
    {% else %}
    driver: "{{ net_def.driver | default('bridge') }}"
    {% endif %}
{% endfor %}
{% endif %}

{% if named_volumes %}
volumes:
{% for vol_id, vol_def in named_volumes.items() %}
  {{ vol_id }}:
    {% if vol_def.driver %}
    driver: "{{ vol_def.driver }}"
    {% endif %}
    {% if vol_def.driver_opts %}
    driver_opts:
      {% for k, v in vol_def.driver_opts.items() %}
      {{ k }}: "{{ v }}"
      {% endfor %}
    {% endif %}
{% endfor %}
{% endif %}